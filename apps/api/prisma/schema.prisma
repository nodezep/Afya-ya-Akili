// AKILI — mental health platform database schema
// PostgreSQL + pgvector (for RAG embeddings)

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

// ---------------------------------------------------------------
// Enums
// ---------------------------------------------------------------

enum Role {
  USER
  THERAPIST
  CORPORATE_ADMIN
  ADMIN
  SUPER_ADMIN
}

enum AuthProvider {
  EMAIL
  GOOGLE
  APPLE
}

enum OtpPurpose {
  LOGIN
  VERIFY_EMAIL
  VERIFY_PHONE
  RESET_PASSWORD
}

enum Gender {
  MALE
  FEMALE
  NON_BINARY
  PREFER_NOT_TO_SAY
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum SessionType {
  VIDEO
  AUDIO
  CHAT
  IN_PERSON
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum RiskLevel {
  NONE
  LOW
  MODERATE
  HIGH
  CRITICAL
}

enum AssessmentType {
  PHQ9
  GAD7
  PSS10
  WHO5
  PCL5
  AUDIT
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum NotificationType {
  SYSTEM
  APPOINTMENT
  CHAT
  MOOD_REMINDER
  JOURNAL_REMINDER
  ASSESSMENT
  BILLING
  THERAPIST
  ORGANIZATION
}

enum NotificationChannel {
  IN_APP
  EMAIL
  PUSH
  SMS
}

enum PaymentProvider {
  STRIPE
  MPESA
  AIRTEL_MONEY
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  REFUNDED
  CANCELLED
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELLED
  EXPIRED
}

enum PlanTier {
  FREE
  PREMIUM
  CORPORATE
}

enum TherapistStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
  SUSPENDED
}

enum OrgMemberStatus {
  INVITED
  ACTIVE
  REMOVED
}

// ---------------------------------------------------------------
// Identity & access
// ---------------------------------------------------------------

model User {
  id              String       @id @default(uuid())
  email           String       @unique
  phone           String?      @unique
  passwordHash    String?
  provider        AuthProvider @default(EMAIL)
  supabaseId      String?      @unique
  role            Role         @default(USER)
  emailVerifiedAt DateTime?
  phoneVerifiedAt DateTime?
  isActive        Boolean      @default(true)
  isBanned        Boolean      @default(false)
  lastLoginAt     DateTime?
  deletedAt       DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  profile            Profile?
  preferences        UserPreference?
  refreshTokens      RefreshToken[]
  otpCodes           OtpCode[]
  therapistProfile   TherapistProfile?
  appointmentsAsUser Appointment[]      @relation("ClientAppointments")
  conversations      Conversation[]
  moodEntries        MoodEntry[]
  journalEntries     JournalEntry[]
  meditationSessions MeditationSession[]
  assessmentResults  AssessmentResult[]
  courseProgress     LessonProgress[]
  courseEnrollments  CourseEnrollment[]
  notifications      Notification[]
  devices            Device[]
  payments           Payment[]
  subscriptions      Subscription[]
  orgMemberships     OrganizationMember[]
  reviewsWritten     TherapistReview[]
  auditLogs          AuditLog[]
  analyticsEvents    AnalyticsEvent[]
  crisisEvents       CrisisEvent[]

  @@index([role])
  @@index([createdAt])
  @@map("users")
}

model Profile {
  id               String    @id @default(uuid())
  userId           String    @unique
  firstName        String
  lastName         String
  displayName      String?
  avatarUrl        String?
  bio              String?
  dateOfBirth      DateTime?
  gender           Gender?
  country          String    @default("KE")
  city             String?
  timezone         String    @default("Africa/Nairobi")
  emergencyContactName  String?
  emergencyContactPhone String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model UserPreference {
  id                 String  @id @default(uuid())
  userId             String  @unique
  locale             String  @default("en")
  theme              String  @default("system")
  emailNotifications Boolean @default(true)
  pushNotifications  Boolean @default(true)
  smsNotifications   Boolean @default(false)
  moodReminderTime   String? // HH:mm in user's timezone
  journalReminderTime String?
  dataSharingOptIn   Boolean @default(false)
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

model RefreshToken {
  id         String    @id @default(uuid())
  userId     String
  tokenHash  String    @unique
  userAgent  String?
  ip         String?
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model OtpCode {
  id        String     @id @default(uuid())
  userId    String
  codeHash  String
  purpose   OtpPurpose
  target    String // email or phone the code was sent to
  attempts  Int        @default(0)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime   @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose])
  @@index([expiresAt])
  @@map("otp_codes")
}

model Device {
  id            String   @id @default(uuid())
  userId        String
  expoPushToken String   @unique
  platform      String // ios | android | web
  lastSeenAt    DateTime @default(now())
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("devices")
}

// ---------------------------------------------------------------
// Organizations (corporate wellness)
// ---------------------------------------------------------------

model Organization {
  id            String   @id @default(uuid())
  name          String
  slug          String   @unique
  logoUrl       String?
  industry      String?
  seats         Int      @default(10)
  contactEmail  String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  members       OrganizationMember[]
  subscriptions Subscription[]

  @@map("organizations")
}

model OrganizationMember {
  id             String          @id @default(uuid())
  organizationId String
  userId         String
  isAdmin        Boolean         @default(false)
  status         OrgMemberStatus @default(INVITED)
  invitedEmail   String?
  joinedAt       DateTime?
  createdAt      DateTime        @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
  @@map("organization_members")
}

// ---------------------------------------------------------------
// Therapists & appointments
// ---------------------------------------------------------------

model TherapistProfile {
  id             String          @id @default(uuid())
  userId         String          @unique
  title          String // e.g. "Clinical Psychologist"
  licenseNumber  String
  licenseBody    String
  yearsExperience Int            @default(0)
  specialties    String[]
  languages      String[]        @default(["en"])
  education      String?
  about          String?
  hourlyRateCents Int            @default(500000) // KES cents
  currency       String          @default("KES")
  status         TherapistStatus @default(PENDING_REVIEW)
  acceptsInsurance Boolean       @default(false)
  ratingAvg      Float           @default(0)
  ratingCount    Int             @default(0)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  availability  AvailabilitySlot[]
  appointments  Appointment[]      @relation("TherapistAppointments")
  reviews       TherapistReview[]

  @@index([status])
  @@map("therapist_profiles")
}

model AvailabilitySlot {
  id          String   @id @default(uuid())
  therapistId String
  dayOfWeek   Int // 0 = Sunday .. 6 = Saturday
  startTime   String // "09:00" therapist-local
  endTime     String // "17:00"
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  therapist TherapistProfile @relation(fields: [therapistId], references: [id], onDelete: Cascade)

  @@index([therapistId, dayOfWeek])
  @@map("availability_slots")
}

model Appointment {
  id           String            @id @default(uuid())
  clientId     String
  therapistId  String
  startsAt     DateTime
  endsAt       DateTime
  sessionType  SessionType       @default(VIDEO)
  status       AppointmentStatus @default(PENDING)
  priceCents   Int
  currency     String            @default("KES")
  paymentId    String?           @unique
  notesClient  String?
  notesTherapist String?
  cancelReason String?
  videoRoom    VideoRoom?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  client    User             @relation("ClientAppointments", fields: [clientId], references: [id], onDelete: Cascade)
  therapist TherapistProfile @relation("TherapistAppointments", fields: [therapistId], references: [id], onDelete: Cascade)
  payment   Payment?         @relation(fields: [paymentId], references: [id])

  @@index([clientId, startsAt])
  @@index([therapistId, startsAt])
  @@index([status])
  @@map("appointments")
}

model VideoRoom {
  id            String    @id @default(uuid())
  appointmentId String    @unique
  provider      String    @default("daily")
  roomName      String    @unique
  roomUrl       String
  startedAt     DateTime?
  endedAt       DateTime?
  createdAt     DateTime  @default(now())

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@map("video_rooms")
}

model TherapistReview {
  id          String   @id @default(uuid())
  therapistId String
  authorId    String
  rating      Int // 1..5
  comment     String?
  createdAt   DateTime @default(now())

  therapist TherapistProfile @relation(fields: [therapistId], references: [id], onDelete: Cascade)
  author    User             @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@unique([therapistId, authorId])
  @@map("therapist_reviews")
}

// ---------------------------------------------------------------
// AI chat, memory & RAG
// ---------------------------------------------------------------

model Conversation {
  id         String    @id @default(uuid())
  userId     String
  title      String    @default("New conversation")
  summary    String? // rolling memory summary maintained by the AI service
  riskLevel  RiskLevel @default(NONE)
  isArchived Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([userId, updatedAt])
  @@map("conversations")
}

model Message {
  id             String      @id @default(uuid())
  conversationId String
  role           MessageRole
  content        String
  sentimentScore Float? // -1 .. 1
  riskLevel      RiskLevel   @default(NONE)
  tokensIn       Int?
  tokensOut      Int?
  createdAt      DateTime    @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("messages")
}

model KnowledgeDocument {
  id        String   @id @default(uuid())
  title     String
  source    String // url / filename / "internal"
  category  String   @default("general")
  locale    String   @default("en")
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  chunks DocumentChunk[]

  @@map("knowledge_documents")
}

model DocumentChunk {
  id         String                       @id @default(uuid())
  documentId String
  chunkIndex Int
  content    String
  embedding  Unsupported("vector(1536)")?

  document KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, chunkIndex])
  @@map("document_chunks")
}

model CrisisEvent {
  id             String    @id @default(uuid())
  userId         String
  conversationId String?
  riskLevel      RiskLevel
  trigger        String // excerpt that triggered detection
  acknowledgedBy String? // admin user id
  acknowledgedAt DateTime?
  createdAt      DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@map("crisis_events")
}

// ---------------------------------------------------------------
// Wellbeing tools
// ---------------------------------------------------------------

model MoodEntry {
  id        String   @id @default(uuid())
  userId    String
  score     Int // 1..10
  emotions  String[] @default([])
  note      String?
  factors   String[] @default([]) // sleep, work, family...
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("mood_entries")
}

model JournalEntry {
  id             String   @id @default(uuid())
  userId         String
  title          String
  content        String
  tags           String[] @default([])
  sentimentScore Float?
  isFavorite     Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("journal_entries")
}

model Meditation {
  id           String        @id @default(uuid())
  title        String
  description  String
  category     String // sleep, anxiety, focus, breathing...
  durationSec  Int
  audioUrl     String
  imageUrl     String?
  narrator     String?
  locale       String        @default("en")
  isPremium    Boolean       @default(false)
  status       ContentStatus @default(PUBLISHED)
  playCount    Int           @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  sessions MeditationSession[]

  @@index([category])
  @@map("meditations")
}

model MeditationSession {
  id           String    @id @default(uuid())
  userId       String
  meditationId String
  startedAt    DateTime  @default(now())
  completedAt  DateTime?
  progressSec  Int       @default(0)

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  meditation Meditation @relation(fields: [meditationId], references: [id], onDelete: Cascade)

  @@index([userId, startedAt])
  @@map("meditation_sessions")
}

// ---------------------------------------------------------------
// Assessments
// ---------------------------------------------------------------

model AssessmentTemplate {
  id          String         @id @default(uuid())
  type        AssessmentType @unique
  name        String
  description String
  frequencyDays Int          @default(14) // suggested re-take interval
  questions   AssessmentQuestion[]
  results     AssessmentResult[]

  @@map("assessment_templates")
}

model AssessmentQuestion {
  id         String @id @default(uuid())
  templateId String
  order      Int
  text       String
  // options stored as JSON: [{label, value}]
  options    Json

  template AssessmentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, order])
  @@map("assessment_questions")
}

model AssessmentResult {
  id         String   @id @default(uuid())
  userId     String
  templateId String
  answers    Json // [{questionId, value}]
  totalScore Int
  severity   String // e.g. "moderate"
  createdAt  DateTime @default(now())

  user     User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  template AssessmentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("assessment_results")
}

// ---------------------------------------------------------------
// Learning center
// ---------------------------------------------------------------

model Course {
  id          String        @id @default(uuid())
  title       String
  slug        String        @unique
  description String
  imageUrl    String?
  category    String        @default("general")
  locale      String        @default("en")
  isPremium   Boolean       @default(false)
  status      ContentStatus @default(PUBLISHED)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  lessons     Lesson[]
  enrollments CourseEnrollment[]

  @@index([category])
  @@map("courses")
}

model Lesson {
  id          String   @id @default(uuid())
  courseId    String
  order       Int
  title       String
  contentMd   String // markdown body
  videoUrl    String?
  durationMin Int      @default(5)

  course   Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  progress LessonProgress[]

  @@unique([courseId, order])
  @@map("lessons")
}

model CourseEnrollment {
  id         String    @id @default(uuid())
  userId     String
  courseId   String
  enrolledAt DateTime  @default(now())
  completedAt DateTime?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@map("course_enrollments")
}

model LessonProgress {
  id          String    @id @default(uuid())
  userId      String
  lessonId    String
  completedAt DateTime?
  updatedAt   DateTime  @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@map("lesson_progress")
}

// ---------------------------------------------------------------
// Notifications
// ---------------------------------------------------------------

model Notification {
  id        String              @id @default(uuid())
  userId    String
  type      NotificationType
  channel   NotificationChannel @default(IN_APP)
  title     String
  body      String
  data      Json?
  readAt    DateTime?
  sentAt    DateTime?
  createdAt DateTime            @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, readAt])
  @@map("notifications")
}

// ---------------------------------------------------------------
// Billing
// ---------------------------------------------------------------

model Plan {
  id                String   @id @default(uuid())
  tier              PlanTier @unique
  name              String
  description       String
  priceMonthlyCents Int
  priceYearlyCents  Int
  currency          String   @default("KES")
  stripePriceMonthly String?
  stripePriceYearly  String?
  features          String[]
  isActive          Boolean  @default(true)

  subscriptions Subscription[]

  @@map("plans")
}

model Subscription {
  id                   String             @id @default(uuid())
  userId               String?
  organizationId       String?
  planId               String
  status               SubscriptionStatus @default(ACTIVE)
  interval             String             @default("month") // month | year
  provider             PaymentProvider    @default(STRIPE)
  stripeSubscriptionId String?            @unique
  currentPeriodStart   DateTime           @default(now())
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user         User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan         Plan          @relation(fields: [planId], references: [id])

  @@index([userId])
  @@index([organizationId])
  @@map("subscriptions")
}

model Payment {
  id            String          @id @default(uuid())
  userId        String
  provider      PaymentProvider
  status        PaymentStatus   @default(PENDING)
  amountCents   Int
  currency      String          @default("KES")
  description   String
  providerRef   String?         @unique // stripe payment_intent / mpesa CheckoutRequestID / airtel txn id
  phone         String? // for mobile money
  metadata      Json?
  failureReason String?
  refundedAt    DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@index([userId, createdAt])
  @@index([status])
  @@map("payments")
}

model WebhookEvent {
  id          String   @id @default(uuid())
  provider    String // stripe | mpesa | airtel | supabase
  eventType   String
  externalId  String?  @unique
  payload     Json
  processedAt DateTime?
  error       String?
  createdAt   DateTime @default(now())

  @@index([provider, createdAt])
  @@map("webhook_events")
}

// ---------------------------------------------------------------
// Analytics & audit
// ---------------------------------------------------------------

model AnalyticsEvent {
  id         String   @id @default(uuid())
  userId     String?
  name       String // e.g. "mood.logged", "chat.message", "page.view"
  properties Json?
  platform   String   @default("web") // web | ios | android
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([name, createdAt])
  @@index([userId, createdAt])
  @@map("analytics_events")
}

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String?
  action     String // e.g. "user.ban", "therapist.approve"
  targetType String?
  targetId   String?
  ip         String?
  metadata   Json?
  createdAt  DateTime @default(now())

  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId, createdAt])
  @@index([action, createdAt])
  @@map("audit_logs")
}

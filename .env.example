# ------------------------------------------------------------------
# AKILI environment configuration (copy to .env and fill in values)
# ------------------------------------------------------------------

# --- Core ---
NODE_ENV=development
API_PORT=4000
API_URL=http://localhost:4000
WEB_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:8081

# --- Database (PostgreSQL with pgvector) ---
DATABASE_URL=postgresql://akili:akili@localhost:5432/akili?schema=public

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- JWT / Sessions ---
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# --- Supabase (Google / Apple OAuth + auth webhooks) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# --- AI (any OpenAI-compatible API) ---
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_CHAT_MODEL=gpt-4o-mini
AI_EMBEDDING_MODEL=text-embedding-3-small
AI_EMBEDDING_DIM=1536

# --- Email (SMTP) ---
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="AKILI <no-reply@akili.health>"

# --- SMS / OTP ---
SMS_PROVIDER=africastalking
AFRICASTALKING_API_KEY=
AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_SENDER_ID=AKILI

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PREMIUM_MONTHLY=
STRIPE_PRICE_PREMIUM_YEARLY=

# --- M-Pesa (Safaricom Daraja) ---
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=174379
MPESA_PASSKEY=
MPESA_CALLBACK_URL=http://localhost:4000/api/v1/billing/mpesa/callback

# --- Airtel Money ---
AIRTEL_ENV=sandbox
AIRTEL_CLIENT_ID=
AIRTEL_CLIENT_SECRET=
AIRTEL_COUNTRY=KE
AIRTEL_CURRENCY=KES
AIRTEL_CALLBACK_URL=http://localhost:4000/api/v1/billing/airtel/callback

# --- Video calls (Daily.co) ---
DAILY_API_KEY=
DAILY_DOMAIN=your-domain.daily.co

# --- Push notifications ---
EXPO_ACCESS_TOKEN=

# --- Web (Next.js public vars) ---
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
